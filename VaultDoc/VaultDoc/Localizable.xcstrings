    "privacy.ai_estimates": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "AI-vurderinger"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI Estimates"
          }
        }
      }
    },
    "privacy.ai_estimates_body": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VaultDoc sender genstandsoplysninger til Anthropic API'et, når du anmoder om en AI-vurdering. API-nøglen håndteres i appkonfigurationen og ikke af slutbrugere i Indstillinger."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VaultDoc sends item details to a valuation API when you request an AI estimate. The API key is managed in app configuration, not by end users in Settings."
          }
        }
      }
    },
    "privacy.camera_photos": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamera og billeder"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera & Photos"
          }
        }
      }
    },
    "privacy.camera_photos_body": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "VaultDoc får kun adgang til dit kamera og dit fotobibliotek for at tage og vedhæfte billeder til dine genstande. Billeder gemmes lokalt på din enhed."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VaultDoc accesses your camera and photo library only to capture and attach photos to your items. Photos are stored locally on your device."
          }
        }
      }
    },
    "privacy.contact": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontakt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact"
          }
        }
      }
    },
    "privacy.contact_body": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ved spørgsmål om privatliv bedes du kontakte os via App Store-listen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For privacy inquiries, please contact us through the App Store listing."
          }
        }
      }
    },
    "privacy.data_storage": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Datalagring"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data Storage"
          }
        }
      }
    },
    "privacy.data_storage_body": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "VaultDoc gemmer alle dine data lokalt på din enhed ved brug af SwiftData. Ingen data sendes til eksterne servere, bortset fra når du anmoder om en AI-vurdering, som sender genstandsoplysninger til Anthropic API'et."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VaultDoc stores all your data locally on your device using SwiftData. No data is sent to external servers except when you request an AI estimate, which sends item details to the Valuation API."
          }
        }
      }
    },
