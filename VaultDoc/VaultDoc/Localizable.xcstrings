    "privacy.data_storage_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultDoc gemmer alle dine data lokalt på din enhed ved brug af SwiftData. Ingen data sendes til eksterne servere, bortset fra når du anmoder om en AI-vurdering, som sender genstandsoplysninger til Anthropic API'et."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VaultDoc stores all your data locally on your device using SwiftData. No data is sent to external servers except when you request an AI estimate, which sends item details to the Anthropic API."
          }
        }
      }
